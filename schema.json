{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IT Landscape Completion Output",
  "type": "object",
  "required": [
    "elements",
    "relations"
  ],
  "properties": {
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "name",
          "owner",
          "environment"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "type": {
            "type": "string",
            "enum": [
              "application",
              "database",
              "api",
              "team",
              "business_capability"
            ]
          },
          "name": {
            "type": "string"
          },
          "domain": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "environment": {
            "type": "string",
            "enum": [
              "dev",
              "test",
              "prod"
            ]
          },
          "technology": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source",
          "type",
          "target"
        ],
        "properties": {
          "source": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "owns",
              "uses",
              "reads_from",
              "writes_to",
              "exposes",
              "supports"
            ]
          },
          "target": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}